[MAIN]
py-version = 3.9
jobs = 0
suggestion-mode = yes
ignore = tests, docs, logs, ftp_root, .claude, dist, build

[MESSAGES CONTROL]
disable =
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    too-many-lines,
    too-many-instance-attributes,
    too-many-arguments,
    too-many-locals,
    too-many-branches,
    too-many-statements,
    too-many-public-methods,
    too-few-public-methods,
    too-many-return-statements,
    broad-exception-caught,
    invalid-name,
    line-too-long,
    fixme,
    import-outside-toplevel,
    duplicate-code,
    unused-import,
    unused-argument,
    unused-variable,
    unspecified-encoding,
    redefined-outer-name,
    protected-access,
    wrong-import-order,
    wrong-import-position,
    consider-using-with,
    consider-using-in,
    try-except-raise,
    global-statement,
    global-variable-not-assigned,
    subprocess-run-check

[FORMAT]
max-line-length = 120

[DESIGN]
max-args = 10
max-attributes = 20

[BASIC]
good-names = i,j,k,ip,db,ws,fd,ts,tn,id,_
